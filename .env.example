# ==============================================================================
# Leafwater Skincare Vending Machine - Environment Variables
# ==============================================================================
# Copy this file to .env.local and fill in the values.

# ---------- Leafwater Backend ----------
#NEXT_PUBLIC_API_URL=http://103.131.196.202:8000
NEXT_PUBLIC_API_URL=https://backend.leafwater.in:8001

# ---------- NextAuth ----------
NEXT_PUBLIC_AUTH_SECRET=your-auth-secret-here

# ---------- Site URL (for QR codes) ----------
NEXT_PUBLIC_SITE_URL=https://skincarevendingnew.vercel.app

# ---------- PostHog Analytics ----------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ---------- Flask API ----------
FLASK_SECRET_KEY=
FLASK_DEBUG=true
FLASK_API_URL=http://localhost:5000
NEXT_PUBLIC_FLASK_API_URL=http://localhost:5000

# ---------- SQLite Database ----------
SQLITE_DB_PATH=instance/leafwater.db

# ---------- Razorpay ----------
RAZORPAY_TEST_KEY_ID=
RAZORPAY_TEST_KEY_SECRET=
RAZORPAY_LIVE_KEY_ID=
RAZORPAY_LIVE_KEY_SECRET=

# ---------- STM32 Motor Controller ----------
STM32_PORT=COM3
STM32_MOCK=false
STM32_BAUDRATE=115200
STM32_TIMEOUT_MS=300000
STM32_DELAY_BETWEEN_COMMANDS_MS=2000
STM32_DELAY_BEFORE_FINALIZE_MS=3000
STM32_FINALIZE_MODE=once
STM32_SLOT_ID_OFFSET=-1
STM32_AUTO_TRAY_AFTER_SINGLE=true
STM32_TRAY_BATCH_SIZE=2

# ---------- POSIFLY POS Integration ----------
POSIFLY_API_URL=
POSIFLY_API_KEY=
POSIFLY_OUTLET_REF_ID=LEAFWATER_001
POSIFLY_POS_TERMINAL_ID=VENDING_01

# ---------- LW Analytics Backend (FastAPI at localhost:8000) ----------
# Base URL of the analytics backend
LW_ANALYTICS_URL=http://localhost:8000

# JWT login credentials for dashboard APIs
LW_ANALYTICS_USERNAME=admin
LW_ANALYTICS_PASSWORD=

# Machine identity (must match a registered machine in the analytics backend)
LW_MACHINE_ID=LW-VM-Floor1
LW_MACHINE_NAME=LW VM Floor 1
LW_MACHINE_LOCATION=Floor 1

# X-API-Key for machine-facing endpoints (/posifly/*, /sync, /machines/heartbeat)
LW_MACHINE_API_KEY=
